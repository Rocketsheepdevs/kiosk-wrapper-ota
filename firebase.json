{
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "/manifest.json",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=60, must-revalidate" },
          { "key": "Content-Type", "value": "application/json" }
        ]
      }
    ]
  }
}
